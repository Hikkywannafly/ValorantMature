<Page
    x:Class="ValorantUnlocker.Views.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:b="clr-namespace:ValorantUnlocker.Behaviors"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Trang chính">

    <Grid Margin="28,20,28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TextBlock FontTypography="Title" Text="ValorantMature Public" />

        <ui:Card
            Grid.Row="1"
            Margin="0,14,0,0"
            Padding="16,14"
            Background="{Binding StatusBackgroundBrush}"
            BorderBrush="{Binding StatusBorderBrush}"
            BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Ellipse
                        Width="14"
                        Height="14"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Fill="{Binding StatusBrush}" />
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <ui:TextBlock FontTypography="BodyStrong" Text="{Binding StatusText}" />
                        <ui:TextBlock
                            Margin="0,2,0,0"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="{Binding DescText}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>

                <ui:Button
                    x:Name="BtnMonitor"
                    Grid.Column="1"
                    MinWidth="104"
                    Margin="16,0,0,0"
                    VerticalAlignment="Center"
                    Appearance="Primary"
                    Click="BtnMonitor_Click"
                    Content="Tạm dừng" />
                <ui:Button
                    x:Name="BtnRestore"
                    Grid.Column="2"
                    MinWidth="112"
                    Margin="8,0,0,0"
                    VerticalAlignment="Center"
                    Click="BtnRestore_Click"
                    Content="Khôi phục"
                    Icon="{ui:SymbolIcon ArrowReset24}" />
                <ui:Button
                    x:Name="BtnChoose"
                    Grid.Column="3"
                    MinWidth="120"
                    Margin="8,0,0,0"
                    VerticalAlignment="Center"
                    Appearance="Secondary"
                    Click="BtnChoose_Click"
                    Content="Thư mục game"
                    Icon="{ui:SymbolIcon FolderOpen24}" />
            </Grid>
        </ui:Card>

        <ui:Card Grid.Row="2" Margin="0,12,0,0" Padding="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border
                    Grid.Column="0"
                    Height="124"
                    ClipToBounds="True"
                    CornerRadius="8,0,0,8">
                    <Border.Background>
                        <ImageBrush ImageSource="pack://application:,,,/Assets/maucam.png" Stretch="UniformToFill" />
                    </Border.Background>
                </Border>
                <StackPanel Grid.Column="1" Margin="16,14,16,14" VerticalAlignment="Center">
                    <ui:TextBlock FontTypography="BodyStrong" Text="Bản public chỉ chứa phần kiểm chứng được" />
                    <ui:TextBlock Margin="0,8,0,0" Text="Có: giao diện WPF, dò thư mục Paks, sao lưu/xoá/khôi phục logo VNG." />
                    <ui:TextBlock
                        Margin="0,4,0,0"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="Không có: key/license, backend, cloud sync, máu đỏ, xác chết, đổi màu tâm." />
                </StackPanel>
            </Grid>
        </ui:Card>

        <ui:Card
            Grid.Row="3"
            Margin="0,12,0,0"
            Padding="8"
            VerticalAlignment="Stretch"
            VerticalContentAlignment="Stretch">
            <DockPanel>
                <ui:TextBlock
                    Margin="8,4,0,8"
                    DockPanel.Dock="Top"
                    FontTypography="BodyStrong"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                    Text="NHẬT KÝ" />
                <ScrollViewer
                    x:Name="LogScroll"
                    b:WheelScroll.Enabled="True"
                    VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Logs}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock
                                    Margin="8,1"
                                    FontFamily="Consolas"
                                    FontSize="12"
                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                    Text="{Binding}"
                                    TextWrapping="Wrap" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </ui:Card>
    </Grid>
</Page>

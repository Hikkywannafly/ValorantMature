<Page
    x:Class="ValorantUnlocker.Views.Pages.GuidePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:b="clr-namespace:ValorantUnlocker.Behaviors"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Hướng dẫn sử dụng">

    <ScrollViewer b:WheelScroll.Enabled="True" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,20,28,24">
            <ui:TextBlock FontTypography="Title" Text="Hướng dẫn" />

            <ui:TextBlock
                Margin="2,16,0,0"
                FontTypography="BodyStrong"
                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                Text="CÁCH DÙNG" />
            <ui:Card Margin="0,8,0,0" Padding="16,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="34" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Row="0" Width="24" Height="24" CornerRadius="12" Background="{DynamicResource SystemFillColorSuccessBrush}">
                        <ui:TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontTypography="Caption" Text="1" />
                    </Border>
                    <ui:TextBlock Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" FontTypography="BodyStrong" Text="Mở công cụ trước khi vào game" />

                    <Border Grid.Row="1" Width="24" Height="24" Margin="0,10,0,0" CornerRadius="12" Background="{DynamicResource SystemFillColorSuccessBrush}">
                        <ui:TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontTypography="Caption" Text="2" />
                    </Border>
                    <ui:TextBlock Grid.Row="1" Grid.Column="1" Margin="0,10,0,0" VerticalAlignment="Center" FontTypography="BodyStrong" Text="Bấm PLAY trên Riot Client" />

                    <Border Grid.Row="2" Width="24" Height="24" Margin="0,10,0,0" CornerRadius="12" Background="{DynamicResource SystemFillColorSuccessBrush}">
                        <ui:TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontTypography="Caption" Text="3" />
                    </Border>
                    <ui:TextBlock Grid.Row="2" Grid.Column="1" Margin="0,10,0,0" VerticalAlignment="Center" FontTypography="BodyStrong" Text="Thoát game để app tự khôi phục file gốc" />
                </Grid>
            </ui:Card>

            <ui:TextBlock
                Margin="2,16,0,0"
                FontTypography="BodyStrong"
                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                Text="LƯU Ý" />
            <ui:Card Margin="0,8,0,0" Padding="16,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <ui:TextBlock Grid.Row="0" VerticalAlignment="Center" FontTypography="BodyStrong" Text="Đang trong game" />
                    <ui:TextBlock Grid.Row="0" Grid.Column="1" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="Thoát bằng menu khay" />

                    <ui:TextBlock Grid.Row="1" Margin="0,10,0,0" VerticalAlignment="Center" FontTypography="BodyStrong" Text="Riot repair" />
                    <ui:TextBlock Grid.Row="1" Grid.Column="1" Margin="0,10,0,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="Khôi phục gốc trước" />

                    <ui:TextBlock Grid.Row="2" Margin="0,10,0,0" VerticalAlignment="Center" FontTypography="BodyStrong" Text="Sai thư mục" />
                    <ui:TextBlock Grid.Row="2" Grid.Column="1" Margin="0,10,0,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="Chọn lại ở Trang chính" />
                </Grid>
            </ui:Card>
        </StackPanel>
    </ScrollViewer>
</Page>

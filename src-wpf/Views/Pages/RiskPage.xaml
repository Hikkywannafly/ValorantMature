<Page
    x:Class="ValorantUnlocker.Views.Pages.RiskPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:b="clr-namespace:ValorantUnlocker.Behaviors"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Cảnh báo rủi ro">

    <ScrollViewer b:WheelScroll.Enabled="True" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,20,28,24">
            <ui:TextBlock FontTypography="Title" Text="Rủi ro" />

            <ui:Card Margin="0,14,0,0" Padding="16,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="84" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <ui:TextBlock VerticalAlignment="Center" FontTypography="BodyStrong" Text="Mức độ" />
                    <ui:TextBlock
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource SystemFillColorCautionBrush}"
                        Text="Có rủi ro, tự chịu trách nhiệm" />
                </Grid>
            </ui:Card>

            <ui:TextBlock
                Margin="2,16,0,0"
                FontTypography="BodyStrong"
                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                Text="TÁC ĐỘNG" />
            <ui:Card Margin="0,8,0,0" Padding="16,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="108" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <ui:TextBlock Grid.Row="0" FontTypography="BodyStrong" Text="Bản public" />
                    <ui:TextBlock Grid.Row="0" Grid.Column="1" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="Chỉ thao tác file logo VNG cục bộ" />

                    <ui:TextBlock Grid.Row="1" Margin="0,10,0,0" FontTypography="BodyStrong" Text="Logo VNG" />
                    <ui:TextBlock Grid.Row="1" Grid.Column="1" Margin="0,10,0,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="Thấp nếu khôi phục đúng lúc" />

                    <ui:TextBlock Grid.Row="2" Margin="0,10,0,0" FontTypography="BodyStrong" Text="Cloud/key" />
                    <ui:TextBlock Grid.Row="2" Grid.Column="1" Margin="0,10,0,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="Không nằm trong mã nguồn public" />
                </Grid>
            </ui:Card>

            <ui:TextBlock
                Margin="2,16,0,0"
                FontTypography="BodyStrong"
                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                Text="AN TOÀN HƠN" />
            <ui:Card Margin="0,8,0,0" Padding="16,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="136" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <ui:TextBlock Grid.Row="0" FontTypography="BodyStrong" Text="Game update" />
                    <ui:TextBlock Grid.Row="0" Grid.Column="1" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="Chờ cập nhật xong" />

                    <ui:TextBlock Grid.Row="1" Margin="0,10,0,0" FontTypography="BodyStrong" Text="Đang trong trận" />
                    <ui:TextBlock Grid.Row="1" Grid.Column="1" Margin="0,10,0,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="Không tắt bằng Task Manager" />

                    <ui:TextBlock Grid.Row="2" Margin="0,10,0,0" FontTypography="BodyStrong" Text="Riot quét/repair" />
                    <ui:TextBlock Grid.Row="2" Grid.Column="1" Margin="0,10,0,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="Bấm Khôi phục trước" />
                </Grid>
            </ui:Card>
        </StackPanel>
    </ScrollViewer>
</Page>

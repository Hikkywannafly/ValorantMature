<ui:FluentWindow
    x:Class="ValorantUnlocker.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:pages="clr-namespace:ValorantUnlocker.Views.Pages"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="VALORANT Mature Unlocker"
    Width="1080"
    Height="680"
    MinWidth="900"
    MinHeight="560"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica"
    WindowCornerPreference="Round"
    WindowStartupLocation="CenterScreen">

    <!--  Mọi chữ không tự đặt màu sẽ kế thừa màu chữ chính (trắng) của theme Win11 -> không bị về đen.  -->
    <Grid TextElement.Foreground="{DynamicResource TextFillColorPrimaryBrush}">
        <ui:NavigationView
            x:Name="RootNavigation"
            IsBackButtonVisible="Collapsed"
            IsPaneToggleVisible="True"
            PaneDisplayMode="Left"
            TitleBar="{Binding ElementName=TitleBar, Mode=OneWay}">
            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem
                    Content="Trang chính"
                    Icon="{ui:SymbolIcon Home24}"
                    TargetPageType="{x:Type pages:DashboardPage}" />
                <ui:NavigationViewItemSeparator />
                <ui:NavigationViewItem
                    Content="Hướng dẫn"
                    Icon="{ui:SymbolIcon Info24}"
                    TargetPageType="{x:Type pages:GuidePage}" />
                <ui:NavigationViewItem
                    Content="Rủi ro"
                    Icon="{ui:SymbolIcon Warning24}"
                    TargetPageType="{x:Type pages:RiskPage}" />
            </ui:NavigationView.MenuItems>
            <ui:NavigationView.FooterMenuItems>
                <ui:NavigationViewItem
                    Content="Liên hệ &amp; Hỗ trợ"
                    Icon="{ui:SymbolIcon Chat24}"
                    TargetPageType="{x:Type pages:ContactPage}" />
            </ui:NavigationView.FooterMenuItems>
        </ui:NavigationView>

        <ui:TitleBar
            x:Name="TitleBar"
            Title="VALORANT Mature Unlocker"
            VerticalAlignment="Top">
            <ui:TitleBar.Header>
                <StackPanel
                    Margin="14,0,0,0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <ui:SymbolIcon FontSize="16" Symbol="Shield24" />
                    <ui:TextBlock
                        Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        FontTypography="Body"
                        Text="Public Source Build" />
                </StackPanel>
            </ui:TitleBar.Header>
        </ui:TitleBar>
    </Grid>
</ui:FluentWindow>
